rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if match is open
    function isMatchOpen(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data.status == 'open';
    }

    function isAiUser(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)) &&
             get(/databases/$(database)/documents/users/$(userId)).data.name == 'AI';
    }

    function isValidUserCreate() {
      return request.resource.data.keys().hasOnly([
        'name',
        'photo',
        'points',
        'seasonPoints',
        'correctPredictions',
        'seasonCorrectPredictions',
        'wrongPredictions',
        'seasonWrongPredictions',
        'streak',
        'seasonStreak',
        'accuracy',
        'seasonAccuracy',
        'role'
      ]) &&
      request.resource.data.role == 'user';
    }

    // Users collection rules
    match /users/{userId} {
      // Read: authenticated users can read any user profile
      allow read: if request.auth != null;

      // Create: users can create their own profile
      allow create: if request.auth != null && request.auth.uid == userId;

      // Update: owners or admins (admin needed to assign points on match close)
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());

      // Delete: any authenticated user (needed for name-based migration)
      allow delete: if request.auth != null;
    }

    // Matches collection rules
    match /matches/{matchId} {
      // Read: authenticated users can read matches
      allow read: if request.auth != null;
      
      // Create/Delete/Update: any authenticated user
      allow create, delete, update: if request.auth != null;
    }

    // Seasons collection rules
    match /seasons/{seasonId} {
      // Read: any authenticated user (serve ranking e impostazioni)
      allow read: if request.auth != null;

      // Create/Update/Delete: solo admin
      allow create, update, delete: if isAdmin();
    }

    // PPV bonus marker docs (idempotenza finalizePpv)
    match /ppv_bonus/{ppvId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Votes collection rules (subcollection under matches)
    match /votes/{matchId}/userVotes/{userId} {
      // Read: authenticated users can read votes (for statistics)
      allow read: if request.auth != null;
      
      // Write: users can only write their own vote and only if match is open
      allow create: if request.auth != null &&
                   isMatchOpen(matchId) && (
                     request.auth.uid == userId ||
                     isAiUser(userId)
                   );

      allow update: if request.auth != null && (
                     (isMatchOpen(matchId) && (request.auth.uid == userId || isAiUser(userId))) ||
                     isAdmin()
                   );

      allow write: if false;
      
      // Delete: users can delete their own vote, admins can delete any
      allow delete: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );
    }
  }
}
